<Window x:Class="Sm64DecompLevelViewer.LevelEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SM64 Level Editor" Height="768" Width="1024"
        Background="#1E1E1E" Foreground="#CCCCCC"
        Icon="Assets/icon.jpg"
        Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#252526"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC" />
        <SolidColorBrush x:Key="HeaderBrush" Color="#569CD6"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#3E3E42" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>

        <Style x:Key="RibbonButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1,1,1,0" Margin="0,0,2,0" CornerRadius="3,3,0,0">
                            <ContentPresenter x:Name="content" ContentSource="Header" Margin="10,5" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="#9CDCFE"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#454549"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding" Value="4"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2D2D30" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White" />
            </Style.Resources>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Ribbon -->
            <RowDefinition Height="*"/>    <!-- Workspace -->
        </Grid.RowDefinitions>

        <!-- 1. RIBBON MENU -->
        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <TabControl Background="Transparent" BorderThickness="0">
                
                <TabItem Header="File">
                    <StackPanel Orientation="Horizontal">
                        <Button Click="SaveButton_Click" ToolTip="Save Level" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="💾" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Save" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="LogsButton_Click" ToolTip="View Logs" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="📋" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Logs" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </TabItem>
                
                <TabItem Header="Objects">
                    <StackPanel Orientation="Horizontal">
                        <Button Click="AddObject_Click" ToolTip="Add Normal Object" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="➕" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Object" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="PerformCopy" ToolTip="Copy Object" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="📄" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Copy" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="PerformPaste" ToolTip="Paste Object" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="📋" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Paste" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="RemoveObject_Click" ToolTip="Delete Selected" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="🗑️" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Delete" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Tools">
                    <StackPanel Orientation="Horizontal">
                        <Button Click="ToolsDashboardButton_Click" ToolTip="Open standalone Tools Dashboard Window" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="🛠️" FontSize="20" HorizontalAlignment="Center" Foreground="#007ACC"/>
                                <TextBlock Text="Dashboard" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="TestButton_Click" ToolTip="Test Level (Requires Emulator)" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="🚀" FontSize="20" HorizontalAlignment="Center" Foreground="#B5CEA8"/>
                                <TextBlock Text="Test" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="ActorEditorButton_Click" ToolTip="Actor Viewer &amp; Editor" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="👾" FontSize="20" HorizontalAlignment="Center" Foreground="#CE9178"/>
                                <TextBlock Text="Actors" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="MusicEditorButton_Click" ToolTip="M64 Music Editor" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="🎵" FontSize="20" HorizontalAlignment="Center" Foreground="#4FC1FF"/>
                                <TextBlock Text="Music" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="LevelMeshEditorButton_Click" ToolTip="Collision &amp; Visual Mesh Editor" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="📐" FontSize="20" HorizontalAlignment="Center" Foreground="#E080C0"/>
                                <TextBlock Text="Mesh" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="WarpEditorButton_Click" ToolTip="Warp Nodes Editor" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="🌀" FontSize="20" HorizontalAlignment="Center" Foreground="#35A0D0"/>
                                <TextBlock Text="Warps" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="PaintingEditorButton_Click" ToolTip="Painting Structures Editor" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="🖼️" FontSize="20" HorizontalAlignment="Center" Foreground="#E6A23C"/>
                                <TextBlock Text="Paintings" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="PatchButton_Click" ToolTip="Apply Source Patch (WSL/Git)" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="🩹" FontSize="20" HorizontalAlignment="Center" Foreground="#E57373"/>
                                <TextBlock Text="Patch" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="HelpButton_Click" ToolTip="Editor Help" Style="{StaticResource RibbonButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="❓" FontSize="20" HorizontalAlignment="Center" Foreground="#DCDCAA"/>
                                <TextBlock Text="Help" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Border>

        <!-- 2. MAIN WORKSPACE -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/> <!-- Sidebar -->
                <ColumnDefinition Width="*"/>   <!-- Viewport + Controls -->
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource PanelBackground}" BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Search -->
                        <RowDefinition Height="2*"/>   <!-- Object List -->
                        <RowDefinition Height="3*"/>   <!-- Property Grid -->
                    </Grid.RowDefinitions>

                    <!-- Search -->
                    <Border Background="#333333" Margin="5" CornerRadius="3" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍" VerticalAlignment="Center" Opacity="0.5" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="1" Background="Transparent" Foreground="White" BorderThickness="0" 
                                     Text="Search objects..." FontSize="12" Opacity="0.8" Name="SearchBox"
                                     TextChanged="SearchBox_TextChanged"
                                     GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus"/>
                        </Grid>
                    </Border>

                    <!-- Object/Warp List -->
                    <TabControl x:Name="SidebarTabControl" Grid.Row="1" Margin="0,5">
                        <TabItem Header="Objects">
                            <TreeView x:Name="ObjectTreeView" Background="Transparent" BorderThickness="0"
                                      SelectedItemChanged="ObjectTreeView_SelectedItemChanged" Margin="0,5">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                        <Setter Property="Padding" Value="2"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeViewItem Header="NORMAL" x:Name="NormalObjectsNode" IsExpanded="True" Foreground="#569CD6"/>
                                <TreeViewItem Header="MACRO" x:Name="MacroObjectsNode" IsExpanded="True" Foreground="#6A9955"/>
                                <TreeViewItem Header="SPECIAL" x:Name="SpecialObjectsNode" IsExpanded="True" Foreground="#DCDCAA"/>
                            </TreeView>
                        </TabItem>
                        <TabItem Header="Cutscene">
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Select Spline -->
                                    <RowDefinition Height="*"/>    <!-- List of Points -->
                                    <RowDefinition Height="Auto"/> <!-- Editing details -->
                                    <RowDefinition Height="Auto"/> <!-- Actions -->
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Margin="0,0,0,5">
                                    <TextBlock Text="Select Camera Path:" Foreground="#CCCCCC" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="SplineSelector" SelectionChanged="SplineSelector_SelectionChanged">
                                        <ComboBoxItem Content="Intro Camera Path (Position)" Tag="sIntroStartToPipePosition"/>
                                        <ComboBoxItem Content="Intro Camera Path (Focus)" Tag="sIntroStartToPipeFocus"/>
                                        <ComboBoxItem Content="Intro Pipe to Dialog (Position)" Tag="sIntroPipeToDialogPosition"/>
                                        <ComboBoxItem Content="Intro Pipe to Dialog (Focus)" Tag="sIntroPipeToDialogFocus"/>
                                    </ComboBox>
                                </StackPanel>
                                
                                <ListBox Grid.Row="1" x:Name="SplinePointListBox" SelectionChanged="SplinePointListBox_SelectionChanged" Background="White" Foreground="Black" BorderBrush="#3F3F46" Margin="0,5">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="Black" FontSize="12"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                
                                <StackPanel Grid.Row="2" Margin="0,5" x:Name="SplineEditorFields" Visibility="Collapsed">
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Speed:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="SplineSpeedText" TextChanged="SplineField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                    </Grid>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="X:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="SplineXText" TextChanged="SplineField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                    </Grid>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Y:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="SplineYText" TextChanged="SplineField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                    </Grid>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Z:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="SplineZText" TextChanged="SplineField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                    </Grid>
                                </StackPanel>
                                
                                <Grid Grid.Row="3" Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" Grid.Column="0" Content="Add Point" Click="AddSplinePoint_Click" Margin="2" Background="#007ACC" Foreground="White" BorderThickness="0" Padding="5"/>
                                    <Button Grid.Row="0" Grid.Column="1" Content="Remove Point" Click="RemoveSplinePoint_Click" Margin="2" Background="#D13438" Foreground="White" BorderThickness="0" Padding="5"/>
                                    <Button Grid.Row="1" Grid.ColumnSpan="2" Content="🎥 Play Path Preview" Click="PlayPathPreview_Click" Margin="2,5" Background="#107C41" Foreground="White" BorderThickness="0" Padding="6"/>
                                </Grid>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Mesh">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Dropdown selection -->
                                    <RowDefinition Height="Auto"/> <!-- List of items (fixed height) -->
                                    <RowDefinition Height="*"/>    <!-- Scrollable fields and actions -->
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Margin="0,0,0,5">
                                    <TextBlock Text="Select Geometry Type:" Foreground="#CCCCCC" Margin="0,0,0,3"/>
                                    <ComboBox x:Name="MeshTypeSelector" SelectionChanged="MeshTypeSelector_SelectionChanged">
                                        <ComboBoxItem Content="Collision Vertices" Tag="ColVertices" IsSelected="True"/>
                                        <ComboBoxItem Content="Collision Triangles" Tag="ColTriangles"/>
                                        <ComboBoxItem Content="Water Boxes" Tag="WaterBoxes"/>
                                    </ComboBox>
                                </StackPanel>
                                
                                <ListBox Grid.Row="1" x:Name="MeshItemListBox" Height="100" SelectionChanged="MeshItemListBox_SelectionChanged" Background="#252526" Foreground="White" BorderBrush="#3F3F46" Margin="0,5">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayText}" Foreground="White" FontSize="12"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,5">
                                    <StackPanel>
                                        <!-- Vertex Editor Fields -->
                                        <StackPanel x:Name="MeshVertexEditorFields" Visibility="Collapsed" Margin="0,5">
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="X:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshVertXText" TextChanged="MeshVertField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Y:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshVertYText" TextChanged="MeshVertField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Z:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshVertZText" TextChanged="MeshVertField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Triangle Editor Fields -->
                                        <StackPanel x:Name="MeshTriangleEditorFields" Visibility="Collapsed" Margin="0,5">
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="V1:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshTriV1Text" TextChanged="MeshTriField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="V2:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshTriV2Text" TextChanged="MeshTriField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="V3:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshTriV3Text" TextChanged="MeshTriField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Surface:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <ComboBox Grid.Column="1" x:Name="MeshTriSurfaceSelector" SelectionChanged="MeshTriSurfaceSelector_SelectionChanged"/>
                                            </Grid>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Param:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshTriParamText" TextChanged="MeshTriField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Water Box Editor Fields -->
                                        <StackPanel x:Name="MeshWaterEditorFields" Visibility="Collapsed" Margin="0,5">
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="ID:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshWaterIDText" TextChanged="MeshWaterField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="X1:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshWaterX1Text" TextChanged="MeshWaterField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Z1:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshWaterZ1Text" TextChanged="MeshWaterField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="X2:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshWaterX2Text" TextChanged="MeshWaterField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Z2:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshWaterZ2Text" TextChanged="MeshWaterField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Y:" Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" x:Name="MeshWaterYText" TextChanged="MeshWaterField_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" Padding="3"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Mesh Editor Actions -->
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Button Grid.Row="0" Grid.Column="0" Content="Add Item" Click="AddMeshItem_Click" Margin="2" Background="#007ACC" Foreground="White" BorderThickness="0" Padding="5"/>
                                            <Button Grid.Row="0" Grid.Column="1" Content="Remove Item" Click="RemoveMeshItem_Click" Margin="2" Background="#D13438" Foreground="White" BorderThickness="0" Padding="5"/>
                                            <Button Grid.Row="1" Grid.ColumnSpan="2" Content="💾 Save Mesh Changes" Click="SaveMeshChanges_Click" Margin="2,5" Background="#107C41" Foreground="White" BorderThickness="0" Padding="6"/>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <!-- Property Grid -->
                    <Border Grid.Row="2" BorderBrush="#3F3F46" BorderThickness="0,1,0,0" Padding="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Properties" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
                            
                            <Grid Grid.Row="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="PropertyStack" Visibility="Collapsed">
                                        <Expander IsExpanded="True" Foreground="White">
                                            <Expander.Header>
                                                <TextBlock Text="GENERAL" FontWeight="Bold" Foreground="#9CDCFE"/>
                                            </Expander.Header>
                                            <Grid Margin="5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Model" Grid.Row="0" VerticalAlignment="Center" Margin="0,0,5,5" Foreground="{StaticResource HeaderBrush}"/>
                                                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="ModelTextBox" Background="#333333" Foreground="White" BorderThickness="1" BorderBrush="#3F3F46" TextChanged="Coordinate_TextChanged" VerticalAlignment="Center" Padding="2"/>
                                                    <Button Grid.Column="1" Content="..." Width="25" Margin="5,0,0,0" Background="#3E3E42" Foreground="White" BorderThickness="0" Click="SelectModelButton_Click"/>
                                                </Grid>
                                                
                                                <TextBlock Text="Behavior" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{StaticResource HeaderBrush}"/>
                                                <Grid Grid.Row="1" Grid.Column="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="BehaviorTextBox" IsReadOnly="True" Background="#333333" Foreground="White" BorderThickness="1" BorderBrush="#3F3F46" MouseDoubleClick="BehaviorTextBox_MouseDoubleClick" VerticalAlignment="Center" Padding="2"/>
                                                    <Button Grid.Column="1" Content="..." Width="25" Margin="5,0,0,0" Background="#3E3E42" Foreground="White" BorderThickness="0" Click="SelectBehaviorButton_Click"/>
                                                </Grid>
                                            </Grid>
                                        </Expander>

                                        <Expander IsExpanded="False" Foreground="White" Margin="0,5,0,0">
                                            <Expander.Header>
                                                <TextBlock Text="DATA" FontWeight="Bold" Foreground="#9CDCFE"/>
                                            </Expander.Header>
                                            <Grid Margin="5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Address" Grid.Row="0" Margin="0,0,5,5" Foreground="{StaticResource HeaderBrush}"/>
                                                <TextBox x:Name="AddressTextBox" Grid.Row="0" Grid.Column="1" IsReadOnly="True" Background="#2D2D30" Foreground="#DCDCAA" BorderThickness="0" Margin="0,0,0,5" Padding="2"/>
                                                
                                                <TextBlock Text="Params" Grid.Row="1" Margin="0,0,5,0" Foreground="{StaticResource HeaderBrush}"/>
                                                <TextBox x:Name="ParamsTextBox" Grid.Row="1" Grid.Column="1" Background="#333333" Foreground="#B5CEA8" BorderThickness="1" BorderBrush="#3F3F46" TextChanged="Coordinate_TextChanged" Padding="2"/>
                                            </Grid>
                                        </Expander>

                                        <Expander IsExpanded="True" Foreground="White" Margin="0,5,0,0">
                                            <Expander.Header>
                                                <TextBlock Text="TRANSFORM" FontWeight="Bold" Foreground="#9CDCFE"/>
                                            </Expander.Header>
                                            <Grid Margin="5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="X" Margin="0,0,5,5" Foreground="{StaticResource HeaderBrush}"/>
                                                <TextBox x:Name="PosXTextBox" Grid.Column="1" Background="#333333" Foreground="White" Margin="0,0,5,5" TextChanged="Coordinate_TextChanged" BorderThickness="1" BorderBrush="#3F3F46" Padding="2"/>
                                                <TextBlock Text="Y" Grid.Column="2" Margin="0,0,5,5" Foreground="{StaticResource HeaderBrush}"/>
                                                <TextBox x:Name="PosYTextBox" Grid.Column="3" Background="#333333" Foreground="White" Margin="0,0,0,5" TextChanged="Coordinate_TextChanged" BorderThickness="1" BorderBrush="#3F3F46" Padding="2"/>

                                                <TextBlock Text="Z" Grid.Row="1" Margin="0,0,5,0" Foreground="{StaticResource HeaderBrush}"/>
                                                <TextBox x:Name="PosZTextBox" Grid.Row="1" Grid.Column="1" Background="#333333" Foreground="White" Margin="0,0,5,0" TextChanged="Coordinate_TextChanged" BorderThickness="1" BorderBrush="#3F3F46" Padding="2"/>
                                                <TextBlock Text="RY" Grid.Row="1" Grid.Column="2" Margin="0,0,5,0" Foreground="{StaticResource HeaderBrush}"/>
                                                <TextBox x:Name="RotYTextBox" Grid.Row="1" Grid.Column="3" Background="#333333" Foreground="White" TextChanged="Coordinate_TextChanged" BorderThickness="1" BorderBrush="#3F3F46" Padding="2"/>
                                            </Grid>
                                        </Expander>
                                    </StackPanel>
                                </ScrollViewer>
                                
                                <TextBlock x:Name="NoSelectionText" Text="No object selected" FontStyle="Italic" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5" 
                                           Foreground="White" Margin="0,50,0,0"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- RIGHT WORKSPACE (Viewport + Controls) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Viewport Container -->
                <Border Background="Black" x:Name="RendererContainer" MouseDown="RendererContainer_MouseDown" Focusable="True">
                    <Grid x:Name="HostGrid">
                        <TextBlock Text="3D VIEWER" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" Opacity="0.3"/>
                    </Grid>
                </Border>

                <!-- BOTTOM CONTROLS -->
                <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="0,1,0,0" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <!-- Movement Gizmos -->
                            <ColumnDefinition Width="*"/>    <!-- Sliders -->
                            <ColumnDefinition Width="Auto"/> <!-- Camera Mode -->
                        </Grid.ColumnDefinitions>

                        <!-- Gizmos -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Movement" Foreground="{StaticResource HeaderBrush}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <Grid Width="80" Height="80">
                                    <Button Content="▲" Margin="0,0,0,54" Width="24" Height="24" Background="#DC3545" Foreground="White" Click="GizmoMove_Click" BorderThickness="0"/>
                                    <Button Content="▼" Margin="0,54,0,0" Width="24" Height="24" Background="#DC3545" Foreground="White" Click="GizmoMove_Click" BorderThickness="0"/>
                                    <Button Content="◀" Margin="0,0,54,0" Width="24" Height="24" Background="#28A745" Foreground="White" Click="GizmoMove_Click" BorderThickness="0"/>
                                    <Button Content="▶" Margin="54,0,0,0" Width="24" Height="24" Background="#28A745" Foreground="White" Click="GizmoMove_Click" BorderThickness="0"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Height" Foreground="{StaticResource HeaderBrush}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <Button Content="➕" Width="24" Height="24" Background="#00A2FF" Foreground="White" Margin="0,0,0,5" Click="GizmoMove_Click" BorderThickness="0"/>
                                <Button Content="➖" Width="24" Height="24" Background="#00A2FF" Foreground="White" Click="GizmoMove_Click" BorderThickness="0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Sliders -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="40,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="MOVE SPEED" VerticalAlignment="Center" Foreground="#CE9178" FontWeight="Bold" FontSize="11"/>
                                <Slider Grid.Column="1" Value="100" Minimum="10" Maximum="500" Margin="10,0" ValueChanged="MoveSpeedSlider_ValueChanged" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Grid.Column="2" x:Name="MoveSpeedText" Text="100%" VerticalAlignment="Center" Foreground="White"/>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CAMERA SPEED" VerticalAlignment="Center" Foreground="#CE9178" FontWeight="Bold" FontSize="11"/>
                                <Slider Grid.Column="1" Value="100" Minimum="10" Maximum="500" Margin="10,0" ValueChanged="CameraSpeedSlider_ValueChanged" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Grid.Column="2" x:Name="CameraSpeedText" Text="100%" VerticalAlignment="Center" Foreground="White"/>
                            </Grid>
                        </StackPanel>

                        <!-- Mode & Drop -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <Button Content="Drop To Ground" Padding="10,5" Margin="0,0,0,5" Background="#3E3E42" Foreground="White" BorderThickness="0" Click="DropToGround_Click"/>
                            <ComboBox SelectedIndex="0" Width="120" Background="#333333" Foreground="White" BorderThickness="1" BorderBrush="#3F3F46">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#333333" />
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White" />
                                </ComboBox.Resources>
                                <ComboBoxItem Content="Fly Mode" Background="#333333" Foreground="White"/>
                                <ComboBoxItem Content="Orbit Mode" Background="#333333" Foreground="White"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
