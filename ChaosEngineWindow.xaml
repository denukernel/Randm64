<Window x:Class="Sm64DecompLevelViewer.ChaosEngineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chaos Engine" Height="500" Width="460"
        Background="#121212" Foreground="#E0E0E0"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#333333"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D32F2F"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#F44336"/>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="CHAOS ENGINE" FontSize="22" FontWeight="ExtraBold" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="Inject corruption directly into compiled ROM assets and decomp source" FontSize="11" Foreground="#888888" HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Presets Bar -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock Text="Chaos Preset:" VerticalAlignment="Center" Foreground="#CCCCCC" Margin="0,0,10,0"/>
                <Button Content="Save As..." Click="SavePreset_Click" DockPanel.Dock="Right" Padding="10,4" Margin="5,0,0,0" Background="#3E3E42" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Delete" Click="DeletePreset_Click" DockPanel.Dock="Right" Padding="10,4" Margin="5,0,0,0" Background="#A12424" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <ComboBox x:Name="PresetComboBox" SelectedIndex="0" Height="24" SelectionChanged="PresetComboBox_SelectionChanged" Background="#252526" Foreground="Black" BorderBrush="#3F3F46">
                    <ComboBoxItem Content="Default Settings"/>
                </ComboBox>
            </DockPanel>
        </Border>

        <!-- Configuration -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
            <StackPanel Grid.IsSharedSizeScope="True">
                <!-- Intensify Slider -->
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="Intensify (Corruption Rate):" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF"/>
                            <TextBlock x:Name="IntensifyValueText" Text="10%" FontSize="13" FontWeight="Bold" Foreground="#4CAF50" DockPanel.Dock="Right"/>
                        </DockPanel>
                        <Slider x:Name="IntensifySlider" Minimum="1" Maximum="500" Value="10" TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,10,0,0" ValueChanged="IntensifySlider_ValueChanged"/>
                        <TextBlock x:Name="IntensifyWarningText" Text="⚠️ WARNING: High corruption rates may cause sound driver hangs or total silence!" FontSize="11" Foreground="#FF3333" FontWeight="SemiBold" Margin="0,5,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Corruption Targets -->
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Target Assets" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,10"/>
                        
                        <!-- Level Selection Filter -->
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="Target Level:" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="LevelSelectionComboBox" SelectedIndex="0" Height="24" Width="200" HorizontalAlignment="Left" Background="#252526" Foreground="Black" BorderBrush="#3F3F46">
                                <ComboBoxItem Content="All Levels"/>
                            </ComboBox>
                        </DockPanel>
                        
                        <CheckBox x:Name="TargetMusicNotesCheck" Content="M64 Music Notes (Sequences)" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="True" Checked="TargetMusicNotesCheck_Toggle" Unchecked="TargetMusicNotesCheck_Toggle"/>
                        <!-- Sub-options for M64 Music Notes -->
                        <StackPanel x:Name="MusicNotesOptionsPanel" Margin="20,0,0,8" Visibility="Visible">
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="Modes:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Button x:Name="ConfigureM64ModesButton" Content="Configure M64 Corruption Modes..." Click="ConfigureM64Modes_Click" Height="24" Width="200" HorizontalAlignment="Left" Background="#007ACC" Foreground="White" BorderThickness="0" FontWeight="SemiBold"/>
                            </DockPanel>
                            <StackPanel Margin="0,0,0,4">
                                <RadioButton x:Name="M64AllRadio" Content="Corrupt All Sequences" Foreground="#CCCCCC" IsChecked="True" Checked="M64Radio_Checked" Unchecked="M64Radio_Checked"/>
                                <RadioButton x:Name="M64SelectRadio" Content="Corrupt Selected Sequences" Foreground="#CCCCCC" Margin="0,4,0,0" Checked="M64Radio_Checked" Unchecked="M64Radio_Checked"/>
                            </StackPanel>
                            <ListBox x:Name="M64SelectionListBox" Height="80" SelectionMode="Multiple" Margin="0,4,0,0" Visibility="Collapsed" Background="#252526" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
                        </StackPanel>
                        
                        <CheckBox x:Name="TargetSoundsCheck" Content="Sound Bank Instrument Samples (.aiff)" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="True"/>
                        <CheckBox x:Name="ShuffleSoundsCheck" Content="Randomize/Shuffle Sound Samples (Swap audio files)" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="ShuffleSoundsCheck_Toggle" Unchecked="ShuffleSoundsCheck_Toggle"/>
                        <!-- Sub-options for shuffling sounds -->
                        <StackPanel x:Name="ShuffleSoundsOptionsPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <CheckBox x:Name="ExcludeInstrumentsShuffleCheck" Content="Exclude Instruments (keep instruments clean)" Foreground="#CCCCCC" Margin="0,0,0,6" IsChecked="False"/>
                            <CheckBox x:Name="ExcludeSfxShuffleCheck" Content="Exclude SFX (keep voices &amp; sound effects clean)" Foreground="#CCCCCC" IsChecked="False"/>
                            <CheckBox x:Name="ShuffleSfxOnlyCheck" Content="Shuffle SFX amongst themselves only" Foreground="#CCCCCC" Margin="0,6,0,0" IsChecked="False"/>
                            <CheckBox x:Name="SfxIdentityShuffleCheck" Content="Shuffle/Swap Sound Identities (Change which sound plays)" Foreground="#CCCCCC" Margin="0,6,0,0" IsChecked="True"/>
                            <CheckBox x:Name="SfxPitchVariationCheck" Content="Apply Random Pitch Variation" Foreground="#CCCCCC" Margin="0,6,0,0" IsChecked="False"/>
                            <DockPanel Margin="0,6,0,0">
                                <TextBlock Text="SFX Randomizer Mode:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="SfxRandomizerModeComboBox" SelectedIndex="0" Height="24" Width="200" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Pure Shuffle (Swap Only)"/>
                                    <ComboBoxItem Content="High Pitch (Chipmunk)"/>
                                    <ComboBoxItem Content="Low Pitch (Demonic)"/>
                                    <ComboBoxItem Content="Chaotic Pitch (Random)"/>
                                    <ComboBoxItem Content="Reverse Playback (Backwards)"/>
                                    <ComboBoxItem Content="Glitched Truncation (Shortened)"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>
                        
                        <CheckBox x:Name="ReplaceSfxCheck" Content="Replace Selected SFX with Specific Sound" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="ReplaceSfxCheck_Toggle" Unchecked="ReplaceSfxCheck_Toggle"/>
                        <!-- Sub-options for replacing SFX -->
                        <StackPanel x:Name="ReplaceSfxPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <Button Content="Configure Sound / Instrument Replacements..." Click="ConfigureSoundReplacer_Click" Height="28" Width="300" HorizontalAlignment="Left" Background="#007ACC" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Margin="0,4,0,4"/>
                            <TextBlock x:Name="ActiveReplacementsSummaryText" Text="Active replacement rules: 0" Foreground="#999999" Margin="0,2,0,0"/>
                        </StackPanel>
                        
                        <CheckBox x:Name="RandomizeDlCheck" Content="Display List (F3DEX) Randomizer" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="RandomizeDlCheck_Toggle" Unchecked="RandomizeDlCheck_Toggle"/>
                        <!-- Sub-options for Display List Randomizer -->
                        <StackPanel x:Name="DlRandomizerPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <DockPanel>
                                <TextBlock Text="Mode:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="DlRandomizerModeComboBox" SelectedIndex="0" Height="24" Width="200" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Rainbow World (Vertex Colors)"/>
                                    <ComboBoxItem Content="Faceless Mario (No UVs)"/>
                                    <ComboBoxItem Content="Normal Inversion"/>
                                    <ComboBoxItem Content="Texture Scrambler (UV Size)"/>
                                    <ComboBoxItem Content="Polygon Exploder"/>
                                    <ComboBoxItem Content="Voxelizer Snap"/>
                                    <ComboBoxItem Content="UV Swap"/>
                                    <ComboBoxItem Content="Scale Distortion"/>
                                    <ComboBoxItem Content="Faceless Mario V2 (Castle Glow &amp; Crystal Water)"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>

                        <CheckBox x:Name="DlExclusionCheck" Content="Display List Exclusion Mode" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="DlExclusionCheck_Toggle" Unchecked="DlExclusionCheck_Toggle"/>
                        <!-- Sub-options for Display List Exclusion Mode -->
                        <StackPanel x:Name="DlExclusionPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <Button Content="Configure Exclusions..." Click="OpenDlExclusionWindow_Click" Height="26" Width="220" HorizontalAlignment="Left" Background="#007ACC" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,8"/>
                        </StackPanel>
                        
                        <CheckBox x:Name="RandomizeMarioColorsCheck" Content="Randomize Mario Colors (Shirt, Overalls, Cap)" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="RandomizeMarioColorsCheck_Toggle" Unchecked="RandomizeMarioColorsCheck_Toggle"/>
                        <!-- Sub-options for Mario Colors -->
                        <StackPanel x:Name="MarioColorsOptionsPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="Target Area:" Foreground="#999999" VerticalAlignment="Center" Width="80"/>
                                <ComboBox x:Name="MarioColorsAreaComboBox" SelectedIndex="0" Height="24" Width="200" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Everything (All Areas)"/>
                                    <ComboBoxItem Content="Shirt &amp; Cap Only"/>
                                    <ComboBoxItem Content="Overalls Only"/>
                                    <ComboBoxItem Content="Gloves Only"/>
                                    <ComboBoxItem Content="Shoes &amp; Hair Only"/>
                                    <ComboBoxItem Content="Skin Only"/>
                                    <ComboBoxItem Content="Buttons Only"/>
                                </ComboBox>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="Mode:" Foreground="#999999" VerticalAlignment="Center" Width="80"/>
                                <ComboBox x:Name="MarioColorsModeComboBox" SelectedIndex="0" Height="24" Width="200" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Full Shaded Random"/>
                                    <ComboBoxItem Content="Invert Original Colors"/>
                                    <ComboBoxItem Content="Channel Swap (Hue Shift)"/>
                                    <ComboBoxItem Content="Psychedelic Neon Glow"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>
                        <CheckBox x:Name="TargetModelsCheck" Content="Vertices / Custom 3D Models" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="True"/>
                        <CheckBox x:Name="TargetGoddardCheck" Content="Goddard Physics &amp; Mario Face Vertices" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="True" Checked="TargetGoddardCheck_Toggle" Unchecked="TargetGoddardCheck_Toggle"/>
                        <!-- Sub-options for Goddard Corruptions -->
                        <StackPanel x:Name="GoddardOptionsPanel" Margin="20,0,0,8" Visibility="Visible">
                            <DockPanel>
                                <TextBlock Text="Mode:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="GoddardModeComboBox" SelectedIndex="0" Height="24" Width="200" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Face Jitter (Vibration)"/>
                                    <ComboBoxItem Content="Face Stretch (Meltdown)"/>
                                    <ComboBoxItem Content="Face Squash"/>
                                    <ComboBoxItem Content="Vertex Exploder"/>
                                    <ComboBoxItem Content="Mirror Face (Invert X)"/>
                                    <ComboBoxItem Content="Low Poly Voxelizer"/>
                                    <ComboBoxItem Content="Static Noise"/>
                                    <ComboBoxItem Content="Facial Tremor"/>
                                    <ComboBoxItem Content="Mouth/Eye Warp"/>
                                    <ComboBoxItem Content="Melt Face (Zero Coords)"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>
                        
                        <CheckBox x:Name="GlitchAnimationsCheck" Content="Mario Animation Glitcher" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="GlitchAnimationsCheck_Toggle" Unchecked="GlitchAnimationsCheck_Toggle"/>
                        <!-- Sub-options for Mario Animation Glitcher -->
                        <StackPanel x:Name="AnimationGlitcherPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <DockPanel>
                                <TextBlock Text="Mode:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="AnimationGlitcherModeComboBox" SelectedIndex="0" Height="24" Width="200" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Joint Jitter"/>
                                    <ComboBoxItem Content="Joint Stretch"/>
                                    <ComboBoxItem Content="Angle Invert"/>
                                    <ComboBoxItem Content="Stutter Step"/>
                                    <ComboBoxItem Content="Pose Freeze (T-Pose)"/>
                                    <ComboBoxItem Content="Extreme Twist"/>
                                    <ComboBoxItem Content="Frame Scrambler"/>
                                    <ComboBoxItem Content="Offset Detach (Limbs)"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>
                        
                        <CheckBox x:Name="GlitchHudCheck" Content="HUD Glitcher" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="GlitchHudCheck_Toggle" Unchecked="GlitchHudCheck_Toggle"/>
                        <!-- Sub-options for HUD Glitcher -->
                        <StackPanel x:Name="HudGlitcherPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <DockPanel>
                                <TextBlock Text="Mode:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="HudGlitcherModeComboBox" SelectedIndex="0" Height="24" Width="200" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Position Scramble"/>
                                    <ComboBoxItem Content="Glyph Corruption"/>
                                    <ComboBoxItem Content="Int Format Break"/>
                                    <ComboBoxItem Content="Health Meter Warp"/>
                                    <ComboBoxItem Content="Strobe Stutter"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>
                        
                        <CheckBox x:Name="RandomizeTexturesCheck" Content="Randomize Game Textures (Glitched PNGs)" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="RandomizeTexturesCheck_Toggle" Unchecked="RandomizeTexturesCheck_Toggle"/>
                        <!-- Sub-options for texture randomizer -->
                        <StackPanel x:Name="TextureRandomizeOptionsPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="Mode:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="TextureRandomizeModeComboBox" SelectedIndex="0" Height="24" Width="200" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Texture Swapping (Shuffle)"/>
                                    <ComboBoxItem Content="Color Inversion (Negative)"/>
                                    <ComboBoxItem Content="Hue Shift (Color Cycle)"/>
                                    <ComboBoxItem Content="Grayscale &amp; Desaturate"/>
                                    <ComboBoxItem Content="Noise Injection"/>
                                    <ComboBoxItem Content="Pixelate / Mosaic"/>
                                </ComboBox>
                            </DockPanel>
                            
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="Target:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <RadioButton x:Name="TextureRandomizeAllRadio" Content="All Textures" IsChecked="True" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,15,0" Checked="TextureTarget_Changed" Unchecked="TextureTarget_Changed"/>
                                <RadioButton x:Name="TextureRandomizeSelectedRadio" Content="Selected Only" Foreground="#CCCCCC" VerticalAlignment="Center" Checked="TextureTarget_Changed" Unchecked="TextureTarget_Changed"/>
                            </DockPanel>
                            
                            <Button x:Name="SelectTexturesButton" Content="📁 Select &amp; Preview Textures..." Click="SelectTexturesButton_Click" HorizontalAlignment="Left" Padding="12,4" Margin="47,0,0,4" Visibility="Collapsed"/>
                        </StackPanel>
                        
                        <CheckBox x:Name="ReplaceTexturesCustomCheck" Content="Replace Selected Textures with Specific Texture" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="ReplaceTexturesCustomCheck_Toggle" Unchecked="ReplaceTexturesCustomCheck_Toggle"/>
                        <!-- Sub-options for replacing textures -->
                        <StackPanel x:Name="ReplaceTexturesCustomPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <Button Content="Configure Texture Replacements..." Click="ConfigureTextureReplacer_Click" Height="28" Width="300" HorizontalAlignment="Left" Background="#007ACC" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Margin="0,4,0,4"/>
                            <TextBlock x:Name="ActiveTextureReplacementsSummaryText" Text="Active replacement rules: 0" Foreground="#999999" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Corruption Modes -->
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Corruption Mode" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,8"/>
                        <ComboBox x:Name="ModeComboBox" SelectedIndex="0" Height="28">
                            <ComboBoxItem Content="Byte Swapping (Interleave Glitches)"/>
                            <ComboBoxItem Content="Random Noise / Value Randomizer"/>
                            <ComboBoxItem Content="Bitwise Logical (XOR Masks)"/>
                            <ComboBoxItem Content="Shift Corrupt (Vertex Stretching)"/>
                            <ComboBoxItem Content="Nullify / Zero out (Geometry Voids)"/>
                            <ComboBoxItem Content="Arithmetic Addition (Pitch Transpose / Value Offset)"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Chaos Cheats & Game Logic -->
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Chaos Cheats &amp; Game Logic" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,10"/>
                        <CheckBox x:Name="RandomizeSkyboxCheck" Content="Randomize Level Skyboxes" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False"/>
                        <CheckBox x:Name="RandomizeTextCheck" Content="Randomize Game Text &amp; Dialogs" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="RandomizeTextCheck_Toggle" Unchecked="RandomizeTextCheck_Toggle"/>
                        <!-- Sub-options for text randomizer -->
                        <StackPanel x:Name="TextRandomizeOptionsPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="Randomization Mode:" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="TextRandomizeModeComboBox" SelectedIndex="0" Height="24" Width="180" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Scramble Characters"/>
                                    <ComboBoxItem Content="Word Shuffle"/>
                                    <ComboBoxItem Content="Leet Speak"/>
                                    <ComboBoxItem Content="Alien/Glitch Symbols"/>
                                    <ComboBoxItem Content="Mocking Case"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>

                        <CheckBox x:Name="ScrambleTitleScreenCheck" Content="Title Screen Logo Scrambler" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="ScrambleTitleScreenCheck_Toggle" Unchecked="ScrambleTitleScreenCheck_Toggle"/>
                        <!-- Sub-options for Title Screen Scrambler -->
                        <StackPanel x:Name="TitleScreenScramblerPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <DockPanel>
                                <TextBlock Text="Scrambler Mode:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="TitleScreenScramblerModeComboBox" SelectedIndex="0" Height="24" Width="220" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Mode 0: Disabled"/>
                                    <ComboBoxItem Content="Mode 1: Glitchy Scale Jitter"/>
                                    <ComboBoxItem Content="Mode 2: Vinesauce Spin / Rotation"/>
                                    <ComboBoxItem Content="Mode 3: Melt / Vertical Stretch"/>
                                    <ComboBoxItem Content="Mode 4: Disco Jump"/>
                                    <ComboBoxItem Content="Mode 5: Upside Down / Mirror"/>
                                    <ComboBoxItem Content="Mode 6: Random Warp Jitter"/>
                                    <ComboBoxItem Content="Mode 7: Shrinking Void"/>
                                    <ComboBoxItem Content="Mode 8: Chaotic Skewed"/>
                                    <ComboBoxItem Content="Mode 9: Completely Random Glitch"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>

                        <CheckBox x:Name="RandomizeCutsceneCameraCheck" Content="Intro Cutscene Camera Randomizer" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="RandomizeCutsceneCameraCheck_Toggle" Unchecked="RandomizeCutsceneCameraCheck_Toggle"/>
                        <!-- Sub-options for Cutscene Camera Randomizer -->
                        <StackPanel x:Name="CutsceneCameraPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <DockPanel>
                                <TextBlock Text="Camera Mode:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="CutsceneCameraModeComboBox" SelectedIndex="0" Height="24" Width="220" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Mode 0: Disabled"/>
                                    <ComboBoxItem Content="Mode 1: Random Static Angles"/>
                                    <ComboBoxItem Content="Mode 2: Jittery Handheld Camera"/>
                                    <ComboBoxItem Content="Mode 3: Drunken / Swaying Camera"/>
                                    <ComboBoxItem Content="Mode 4: Spinning Vortex"/>
                                    <ComboBoxItem Content="Mode 5: Close-up Focus"/>
                                    <ComboBoxItem Content="Mode 6: Birds-Eye View"/>
                                    <ComboBoxItem Content="Mode 7: First Person View"/>
                                    <ComboBoxItem Content="Mode 8: Warped Perspective"/>
                                    <ComboBoxItem Content="Mode 9: Completely Chaotic"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>

                        <CheckBox x:Name="LakituCameraChaosCheck" Content="In-Game Lakitu Camera Randomizer" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="LakituCameraChaosCheck_Toggle" Unchecked="LakituCameraChaosCheck_Toggle"/>
                        <!-- Sub-options for Lakitu Camera Randomizer -->
                        <StackPanel x:Name="LakituCameraChaosPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <DockPanel>
                                <TextBlock Text="Camera Mode:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="LakituCameraModeComboBox" SelectedIndex="0" Height="24" Width="220" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Mode 0: Disabled"/>
                                    <ComboBoxItem Content="Mode 1: Handheld Tremor"/>
                                    <ComboBoxItem Content="Mode 2: Top-Down Birds-Eye View"/>
                                    <ComboBoxItem Content="Mode 3: Front Face Cam"/>
                                    <ComboBoxItem Content="Mode 4: Orbiting Vortex"/>
                                    <ComboBoxItem Content="Mode 5: Drunken Sway"/>
                                    <ComboBoxItem Content="Mode 6: Zoom Dilation (Breathing)"/>
                                    <ComboBoxItem Content="Mode 7: 2D Side-Scroller View"/>
                                    <ComboBoxItem Content="Mode 8: Fixed Security Cam"/>
                                    <ComboBoxItem Content="Mode 9: Pitch Flip (Upside Down)"/>
                                    <ComboBoxItem Content="Mode 10: Cycle Modes (Chaos Roulette)"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>

                        <CheckBox x:Name="StartLevelChaosCheck" Content="Start Level Chaos (File Select Warp)" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="StartLevelChaosCheck_Toggle" Unchecked="StartLevelChaosCheck_Toggle"/>
                        <!-- Sub-options for Start Level Chaos -->
                        <StackPanel x:Name="StartLevelChaosPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <DockPanel>
                                <TextBlock Text="Warp Destination:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="StartLevelComboBox" SelectedIndex="0" Height="24" Width="220" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Bob-omb Battlefield (LEVEL_BOB)"/>
                                    <ComboBoxItem Content="Whomp's Fortress (LEVEL_WF)"/>
                                    <ComboBoxItem Content="Jolly Roger Bay (LEVEL_JRB)"/>
                                    <ComboBoxItem Content="Cool, Cool Mountain (LEVEL_CCM)"/>
                                    <ComboBoxItem Content="Big Boo's Haunt (LEVEL_BBH)"/>
                                    <ComboBoxItem Content="Hazy Maze Cave (LEVEL_HMC)"/>
                                    <ComboBoxItem Content="Lethal Lava Land (LEVEL_LLL)"/>
                                    <ComboBoxItem Content="Shifting Sand Land (LEVEL_SSL)"/>
                                    <ComboBoxItem Content="Dire, Dire Docks (LEVEL_DDD)"/>
                                    <ComboBoxItem Content="Snowman's Land (LEVEL_SL)"/>
                                    <ComboBoxItem Content="Wet-Dry World (LEVEL_WDW)"/>
                                    <ComboBoxItem Content="Tall, Tall Mountain (LEVEL_TTM)"/>
                                    <ComboBoxItem Content="Tiny-Huge Island (LEVEL_THI)"/>
                                    <ComboBoxItem Content="Tick Tock Clock (LEVEL_TTC)"/>
                                    <ComboBoxItem Content="Rainbow Ride (LEVEL_RR)"/>
                                    <ComboBoxItem Content="Secret Aquarium (LEVEL_SA)"/>
                                    <ComboBoxItem Content="Cavern of the Metal Cap (LEVEL_COTMC)"/>
                                    <ComboBoxItem Content="Tower of the Wing Cap (LEVEL_TOTWC)"/>
                                    <ComboBoxItem Content="Bowser in the Dark World (LEVEL_BITDW)"/>
                                    <ComboBoxItem Content="Bowser in the Fire Sea (LEVEL_BITFS)"/>
                                    <ComboBoxItem Content="Bowser in the Sky (LEVEL_BITS)"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>

                        <CheckBox x:Name="ChaosLogicJumpWeird" Content="Weird Mario Jumping (Random Velocity)" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False"/>
                        <CheckBox x:Name="ChaosLogicJumpDeath" Content="Deadly Jumping (Mario dies on jump)" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False"/>
                        <CheckBox x:Name="LimboMarioCheck" Content="Limbo Mario Animation Deformer" Foreground="#CCCCCC" Margin="0,0,0,8" IsChecked="False" Checked="LimboMarioCheck_Toggle" Unchecked="LimboMarioCheck_Toggle"/>
                        <!-- Sub-options for Limbo Mario Deformer -->
                        <StackPanel x:Name="LimboMarioPanel" Margin="20,0,0,8" Visibility="Collapsed">
                            <DockPanel>
                                <TextBlock Text="Deform Mode:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="LimboMarioModeComboBox" SelectedIndex="0" Height="24" Width="220" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Mode 0: Disabled"/>
                                    <ComboBoxItem Content="Mode 1: Spine Deform (Backwards Bend)"/>
                                    <ComboBoxItem Content="Mode 2: Helicopter Torso (Continuous Spin)"/>
                                    <ComboBoxItem Content="Mode 3: Folded Sandwich (Forward Fold)"/>
                                    <ComboBoxItem Content="Mode 4: Jittery Seizure Torso (Tremor)"/>
                                    <ComboBoxItem Content="Mode 5: Legless Mario (Walking on stumps)"/>
                                    <ComboBoxItem Content="Mode 6: Spaghetti Limbs (Joint Stretching)"/>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>
                        <CheckBox x:Name="AlienSoundCheatCheck" Content="Alien Sound Glitch (Inject GameShark A031C1AF)" Foreground="#CCCCCC" IsChecked="False"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Action / Status -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                <TextBlock x:Name="StatusTextBlock" Text="Engine ready..." FontSize="11" Foreground="#888888" TextWrapping="Wrap"/>
                <ProgressBar x:Name="CorruptionProgressBar" Height="6" Margin="0,4,0,0" Background="#222" Foreground="{StaticResource AccentBrush}" Visibility="Collapsed"/>
            </StackPanel>

            <Button Grid.Column="1" x:Name="ChaosButton" Content="INFLICT CHAOS!" Click="ChaosButton_Click"
                    Padding="25,12" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" 
                    FontSize="14" FontWeight="Bold" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
