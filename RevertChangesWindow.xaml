<Window x:Class="Sm64DecompLevelViewer.RevertChangesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revert Source Changes" Height="450" Width="600"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#252526"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F1F1F1"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3F3F46"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4F4F56"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Revert Decomp Source Changes" FontSize="18" FontWeight="Bold" Foreground="#E57373"/>
            <TextBlock Text="Choose which changes to revert. You can restore specific backup files (.bak) or perform a full Git checkout to restore the workspace to a clean state." FontSize="11" Foreground="#999999" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Option 1: Git Revert -->
            <Border Grid.Row="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,12">
                <CheckBox x:Name="GitRevertCheck" Foreground="White" IsChecked="False" Checked="GitRevertCheck_Toggle" Unchecked="GitRevertCheck_Toggle">
                    <StackPanel Margin="5,0,0,0">
                        <TextBlock Text="Full Git checkout &amp; clean (Revert all uncommitted files)" FontWeight="Bold" FontSize="12"/>
                        <TextBlock Text="⚠️ Warning: This runs 'git checkout -f &amp;&amp; git clean -fd' inside WSL, discarding ALL local modifications in the repository." FontSize="10.5" Foreground="#FF8A80" TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>
                </CheckBox>
            </Border>

            <!-- Option 2: Restore Backups list -->
            <GroupBox Grid.Row="1" Header="Restore Specific Backup Files (.bak)" BorderBrush="{StaticResource BorderBrush}" Background="{StaticResource PanelBackground}" Foreground="#CCCCCC" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="BackupsListBox" Background="#1E1E1E" BorderBrush="{StaticResource BorderBrush}" Margin="0,0,0,5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled}" Foreground="White" Margin="3" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding RelativePath}"/>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <DockPanel Grid.Row="1">
                        <Button Content="Select All Backups" Click="SelectAll_Click" Margin="0,0,5,0" Height="24"/>
                        <Button Content="Deselect All Backups" Click="DeselectAll_Click" Height="24"/>
                    </DockPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Bottom Controls -->
        <DockPanel Grid.Row="2">
            <Button Content="Cancel" Click="CancelButton_Click" Width="80" Height="26" DockPanel.Dock="Right"/>
            <Button Content="Revert Selected" Click="RevertButton_Click" Width="120" Height="26" DockPanel.Dock="Right" Background="#007ACC" FontWeight="Bold" Margin="0,0,10,0"/>
            <TextBlock x:Name="StatusTextBlock" Text="Scanning for backups..." Foreground="#999999" VerticalAlignment="Center"/>
        </DockPanel>
    </Grid>
</Window>
