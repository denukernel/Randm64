<Window x:Class="Sm64DecompLevelViewer.SoundEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SM64 Sound &amp; SFX Editor" Height="550" Width="850"
        WindowStartupLocation="CenterOwner" Background="#1E1E1E" Foreground="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title / Description -->
            <RowDefinition Height="*"/>    <!-- Main panels -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="0,0,0,12" BorderThickness="0,0,0,1" BorderBrush="#3F3F46" Padding="0,0,0,8">
            <StackPanel>
                <TextBlock Text="🔊 SM64 Sound &amp; SFX Editor" FontSize="18" FontWeight="Bold" Foreground="#D45B0A"/>
                <TextBlock Text="Browse sound banks, preview audio samples, and replace them with custom WAV files." FontSize="11" Foreground="#CCCCCC" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/> <!-- Categories list -->
                <ColumnDefinition Width="3*"/>  <!-- Samples list -->
                <ColumnDefinition Width="2*"/>  <!-- Selected Details & actions -->
            </Grid.ColumnDefinitions>

            <!-- Categories -->
            <GroupBox Grid.Column="0" Header="Categories" BorderBrush="#3F3F46" Foreground="White" Margin="0,0,8,0" Padding="4">
                <ListBox x:Name="CategoryListBox" SelectionChanged="CategoryListBox_SelectionChanged" Background="#252526" Foreground="White" BorderBrush="Transparent"/>
            </GroupBox>

            <!-- Samples List -->
            <GroupBox Grid.Column="1" Header="Audio Samples" BorderBrush="#3F3F46" Foreground="White" Margin="0,0,8,0" Padding="4">
                <ListBox x:Name="SampleListBox" SelectionChanged="SampleListBox_SelectionChanged" Background="#252526" Foreground="White" BorderBrush="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="🎵 " Foreground="#D45B0A"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <!-- Detail & Actions -->
            <GroupBox Grid.Column="2" Header="Details &amp; Actions" BorderBrush="#3F3F46" Foreground="White" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Selected Sample:" FontSize="11" Foreground="#CCCCCC"/>
                        <TextBlock x:Name="SelectedSampleTextBlock" Text="None selected" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" Margin="0,4,0,15" Foreground="#FF8C00"/>

                        <TextBlock Text="File Path:" FontSize="11" Foreground="#CCCCCC"/>
                        <TextBlock x:Name="FilePathTextBlock" Text="-" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,15" Foreground="#999999"/>

                        <Border Background="#2D2D30" CornerRadius="4" Padding="8" Margin="0,5,0,0">
                            <TextBlock Text="Note: Replacing a sample requires importing a standard WAV file (16-bit PCM format is recommended). The editor will automatically handle the conversion back to the big-endian AIFF format used in SM64 decomp." FontSize="10" TextWrapping="Wrap" Foreground="#CCCCCC"/>
                        </Border>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Row="1" Orientation="Vertical">
                        <Button Click="PlayButton_Click" Content="▶ Play Sound" Margin="0,4" Background="#107C41" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="12,8" Cursor="Hand"/>
                        <Button Click="StopButton_Click" Content="■ Stop Playback" Margin="0,4" Background="#D13438" Foreground="White" BorderThickness="0" Padding="12,8" Cursor="Hand"/>
                        <Button Click="ReplaceButton_Click" Content="💾 Replace Sample..." Margin="0,4" Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="12,8" Cursor="Hand"/>
                        <Button x:Name="RevertButton" Click="RevertButton_Click" Content="🔄 Revert to Original" Margin="0,4" Background="#8A4A00" Foreground="White" FontWeight="Bold" BorderThickness="0" Padding="12,8" Cursor="Hand" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Margin="0,8,0,0" BorderThickness="0,1,0,0" BorderBrush="#3F3F46" Padding="0,6,0,0">
            <TextBlock x:Name="StatusTextBlock" Text="Ready" FontSize="11" Foreground="#999999"/>
        </Border>
    </Grid>
</Window>
