<Window x:Class="Sm64DecompLevelViewer.TextureSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Texture Selection &amp; Preview Manager" Height="600" Width="850"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#252526"/>
        <SolidColorBrush x:Key="HeaderBrush" Color="#64B5F6"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F1F1F1"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#3F3F46"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4F4F56"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="🖼️ TEXTURE SELECTION MANAGER" FontSize="16" FontWeight="Bold" Foreground="{StaticResource HeaderBrush}" Margin="0,0,0,10"/>

        <!-- Search and Global Actions -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Search / Filter:" Margin="0,0,10,0"/>
            <TextBox Grid.Column="1" x:Name="SearchTextBox" TextChanged="SearchTextBox_TextChanged" Background="#2D2D30" Foreground="White" BorderBrush="{StaticResource BorderBrush}" Padding="4" VerticalAlignment="Center"/>
            <Button Grid.Column="2" Content="Select All" Click="SelectAll_Click" Margin="10,0,0,0" Padding="8,4"/>
            <Button Grid.Column="3" Content="Deselect All" Click="DeselectAll_Click" Margin="5,0,0,0" Padding="8,4"/>
        </Grid>

        <!-- Main Workspace: List and Preview -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Scanned Textures List -->
            <GroupBox Header="Available Game Textures" BorderBrush="{StaticResource BorderBrush}" Background="{StaticResource PanelBackground}" Foreground="#CCCCCC" Grid.Column="0" Padding="5">
                <ListBox x:Name="TexturesListBox" SelectionChanged="TexturesListBox_SelectionChanged" Background="#1E1E1E" BorderThickness="0" Margin="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsChecked}" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="  -  " Foreground="#666666"/>
                                    <TextBlock Text="{Binding RelativePath}" Foreground="#888888" FontSize="11"/>
                                </StackPanel>
                            </CheckBox>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <!-- Right: Preview Pane -->
            <GroupBox Header="Texture Preview" BorderBrush="{StaticResource BorderBrush}" Background="{StaticResource PanelBackground}" Foreground="#CCCCCC" Grid.Column="2" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Image Display with checkerboard or dark back -->
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="#111" CornerRadius="4" Margin="5" Padding="5">
                        <Grid>
                            <!-- Checkerboard Background Effect -->
                            <Image x:Name="PreviewImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="NoPreviewText" Text="Select a texture to preview" Foreground="#666666" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <!-- Metadata Details -->
                    <StackPanel Grid.Row="1" Margin="5,10,5,5">
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Filename: " Foreground="#999999" Width="80"/>
                            <TextBlock x:Name="MetadataFileName" Text="-" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Dimensions: " Foreground="#999999" Width="80"/>
                            <TextBlock x:Name="MetadataDimensions" Text="-" FontWeight="SemiBold"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Subfolder: " Foreground="#999999" Width="80"/>
                            <TextBlock x:Name="MetadataSubfolder" Text="-" FontSize="11" TextWrapping="Wrap" Foreground="#888888"/>
                        </DockPanel>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Lower Actions -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <TextBlock x:Name="SelectedCountTextBlock" Text="Selected: 0 / 0 textures" VerticalAlignment="Center" Foreground="#888888"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Click="Ok_Click" Width="100" Background="#007ACC" FontWeight="Bold"/>
                <Button Content="Cancel" Click="Cancel_Click" Width="100" Margin="10,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
