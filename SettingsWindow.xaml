<Window x:Class="Sm64DecompLevelViewer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editor Settings" Height="300" Width="400"
        Background="#1E1E1E" Foreground="#CCCCCC"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#252526"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#00A2FF"/>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Camera Settings" FontSize="18" FontWeight="Bold" Foreground="#569CD6" Margin="0,0,0,20"/>

        <!-- Move Speed -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <DockPanel>
                <TextBlock Text="Camera Move Speed: " VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Value, ElementName=MoveSpeedSlider, StringFormat={}{0:F0}}" FontWeight="Bold" DockPanel.Dock="Right"/>
            </DockPanel>
            <Slider x:Name="MoveSpeedSlider" Minimum="100" Maximum="5000" TickFrequency="100" IsSnapToTickEnabled="True" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Rotation Speed -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <DockPanel>
                <TextBlock Text="Rotation Sensitivity: " VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Value, ElementName=RotationSlider, StringFormat={}{0:F3}}" FontWeight="Bold" DockPanel.Dock="Right"/>
            </DockPanel>
            <Slider x:Name="RotationSlider" Minimum="0.005" Maximum="0.1" TickFrequency="0.005" IsSnapToTickEnabled="True" Margin="0,5,0,0"/>
        </StackPanel>

        <Button Grid.Row="5" Content="Save Settings" Click="SaveButton_Click"
                Padding="20,8" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" HorizontalAlignment="Right" Cursor="Hand"/>
    </Grid>
</Window>
