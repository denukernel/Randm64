<Window x:Class="Sm64DecompLevelViewer.CustomBehaviorBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Behavior Builder" Height="500" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#CCCCCC"
        ShowInTaskbar="False">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground" Color="#252526"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
        
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" BorderThickness="1,1,1,0" BorderBrush="{TemplateBinding BorderBrush}" Background="{TemplateBinding Background}" CornerRadius="4,4,0,0" Margin="2,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1E1E1E"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3F3F46"/>
                                <Setter Property="Foreground" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Custom Behavior Builder" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
        
        <TabControl x:Name="MainTabControl" Grid.Row="1">
            <!-- Tab 1: Actor Selection -->
            <TabItem x:Name="ActorTab" Header="1. Select Actor &amp; Name">
                <Grid Margin="15">
                    <StackPanel VerticalAlignment="Center" MaxWidth="450">
                        <TextBlock Text="Behavior Name:" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox x:Name="BehaviorNameTextBox" Text="bhvCustomMyObject" Height="28" Background="#333333" Foreground="White" BorderBrush="{StaticResource BorderBrush}" Padding="4" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="Preferred Actor Model (Editor Viewport Preview):" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ActorModelComboBox" Height="28" Background="#333333" Foreground="Black" BorderBrush="{StaticResource BorderBrush}" Margin="0,0,0,30"/>
                        
                        <Button Content="Next: Configure AI &amp; Interactions ➡️" Height="36" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="NextButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            
            <!-- Tab 2: Logic Builder -->
            <TabItem x:Name="LogicTab" Header="2. AI Logic &amp; Interactions">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left Column: Actions -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="What should the object do? (AI Action)" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                        
                        <RadioButton x:Name="AiPatrol" Content="🚶 Patrol (Walk back &amp; forth)" Foreground="#CCCCCC" Margin="0,0,0,10" IsChecked="True"/>
                        <RadioButton x:Name="AiChase" Content="🏃 Chase Mario (Follow position)" Foreground="#CCCCCC" Margin="0,0,0,10"/>
                        <RadioButton x:Name="AiJump" Content="🦘 Jump Repeatedly (Hop up/down)" Foreground="#CCCCCC" Margin="0,0,0,10"/>
                        <RadioButton x:Name="AiSpin" Content="🔄 Spin Around (Yaw rotation)" Foreground="#CCCCCC" Margin="0,0,0,10"/>
                        <RadioButton x:Name="AiFloat" Content="🎈 Float Up &amp; Down (Sine wave)" Foreground="#CCCCCC" Margin="0,0,0,10"/>
                        <RadioButton x:Name="AiPassive" Content="🛑 Stand Still (Passive)" Foreground="#CCCCCC" Margin="0,0,0,10"/>
                    </StackPanel>
                    
                    <!-- Right Column: Interactions -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Interactions &amp; Physics" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                        
                        <CheckBox x:Name="IntSolid" Content="🧱 Solid Object (Collision bounds)" Foreground="#CCCCCC" Margin="0,0,0,10" IsChecked="True"/>
                        <CheckBox x:Name="IntDamage" Content="💥 Damage Mario on touch" Foreground="#CCCCCC" Margin="0,0,0,10"/>
                        <CheckBox x:Name="IntGrabbable" Content="📦 Grabbable / Throw-able" Foreground="#CCCCCC" Margin="0,0,0,10"/>
                        <CheckBox x:Name="IntCollectible" Content="🪙 Coin Collectible (Plays sound)" Foreground="#CCCCCC" Margin="0,0,0,10"/>
                        <CheckBox x:Name="IntClimbable" Content="🪜 Climbable Pole" Foreground="#CCCCCC" Margin="0,0,0,10"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!-- Bottom Action bar -->
        <DockPanel Grid.Row="2" Margin="0,15,0,0">
            <TextBlock x:Name="StatusTextBlock" Text="Configure object name and model parameters." VerticalAlignment="Center" Foreground="#888888" FontStyle="Italic"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Create &amp; Register Behavior" Click="CreateBehavior_Click" Width="200" Margin="0,0,10,0"
                        Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Padding="8" FontWeight="Bold" Cursor="Hand"/>
                <Button Content="Cancel" Click="CancelButton_Click" Width="80"
                        Background="#3E3E42" Foreground="White" BorderThickness="0" Padding="8" Cursor="Hand"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
