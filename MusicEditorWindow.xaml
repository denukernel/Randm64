<Window x:Class="Sm64DecompLevelViewer.MusicEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="M64 Music Sequencer &amp; Piano Roll" Height="650" Width="1000"
        WindowStartupLocation="CenterOwner" Background="#1E1E1E" Foreground="White"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <!-- Dark scrollbar style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Piano + Grid ScrollViewers -->
            <RowDefinition Height="Auto"/> <!-- Status / Saved Details Bar -->
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Row 0, Col 0: File & App Controls -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Click="SaveButton_Click" ToolTip="Save to camera.c &amp; M64" Margin="2" Background="#007ACC" Foreground="White" BorderThickness="0" Padding="12,6" FontSize="12">💾 Save M64</Button>
                    <Button Click="ImportMidiButton_Click" ToolTip="Import MIDI file to sequencer" Margin="2" Background="#6B6B6B" Foreground="White" BorderThickness="0" Padding="12,6" FontSize="12">🎵 Import MIDI</Button>
                    <Button Click="SoundEditorButton_Click" ToolTip="Open SM64 Sound &amp; SFX Editor" Margin="2" Background="#D45B0A" Foreground="White" BorderThickness="0" Padding="12,6" FontSize="12">🔊 SFX Editor</Button>
                    <Button Click="DisassembleButton_Click" ToolTip="View M64 Disassembly (WSL)" Margin="2" Background="#4F4F4F" Foreground="White" BorderThickness="0" Padding="12,6" FontSize="12">🔍 View Disassembly</Button>
                    <Button Click="HelpButton_Click" ToolTip="Music Editor Keyboard &amp; Mouse Controls" Margin="2" Background="#4F4F4F" Foreground="White" BorderThickness="0" Padding="12,6" FontSize="12">❓ Help</Button>
                </StackPanel>

                <!-- Row 0, Col 1: Track Details -->
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Sequence:" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Button x:Name="SequenceSelectButton" Click="SequenceSelectButton_Click" Content="Select Sequence..." Width="180" Background="#3E3E42" Foreground="White" BorderThickness="0" Margin="0,0,15,0" Padding="8,4" FontSize="12" ToolTip="Click to search and select sound sequences"/>

                    <TextBlock Text="Active Channel:" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="ChannelSelector" SelectionChanged="ChannelSelector_SelectionChanged" Width="55" Background="#333337" Foreground="Black" BorderBrush="#3F3F46" Margin="0,0,15,0">
                        <ComboBoxItem Content="0" IsSelected="True"/>
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                        <ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="6"/>
                        <ComboBoxItem Content="7"/>
                        <ComboBoxItem Content="8"/>
                        <ComboBoxItem Content="9"/>
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="11"/>
                        <ComboBoxItem Content="12"/>
                        <ComboBoxItem Content="13"/>
                        <ComboBoxItem Content="14"/>
                        <ComboBoxItem Content="15"/>
                    </ComboBox>

                    <TextBlock Text="Instrument:" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="InstrumentSelector" SelectionChanged="InstrumentSelector_SelectionChanged" Width="100" Background="#333337" Foreground="Black" BorderBrush="#3F3F46" Margin="0,0,15,0"/>
                    
                    <TextBlock Text="Vol:" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Slider x:Name="VolumeSlider" Minimum="0" Maximum="127" Value="127" Width="80" VerticalAlignment="Center" ValueChanged="VolumeSlider_ValueChanged" ToolTip="Channel Volume (0-127)"/>
                    <TextBlock x:Name="VolumeLabel" Text="127" Foreground="White" Width="25" TextAlignment="Right" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>

                <!-- Row 1, Col 0: Playback Controls & Mode Selector -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,6,0,0">
                    <Button Click="PlayButton_Click" ToolTip="Play Sequence" Margin="2" Background="#107C41" Foreground="White" BorderThickness="0" Padding="12,6" FontSize="12">▶ Play</Button>
                    <Button Click="StopButton_Click" ToolTip="Stop" Margin="2" Background="#D13438" Foreground="White" BorderThickness="0" Padding="12,6" FontSize="12">■ Stop</Button>
                    <CheckBox x:Name="UseMidiSynthCheckBox" IsChecked="True" Content="Clean MIDI Synth" Foreground="#CCCCCC" Margin="10,0,15,0" VerticalAlignment="Center" ToolTip="Use clean Windows General MIDI Synth. Recommended to avoid lag/stutter from WPF MediaPlayer."/>
                    
                    <TextBlock Text="Playback Mode:" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <ComboBox x:Name="PlaybackModeComboBox" SelectionChanged="PlaybackModeComboBox_SelectionChanged" Width="140" Background="#333337" Foreground="Black" BorderBrush="#3F3F46" VerticalAlignment="Center" SelectedIndex="0">
                        <ComboBoxItem Content="Play All Channels"/>
                        <ComboBoxItem Content="Play Active Channel Only"/>
                        <ComboBoxItem Content="Play Selected Channels..."/>
                    </ComboBox>
                </StackPanel>

                <!-- Row 1, Col 1: Editing / Effects Controls -->
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,6,0,0">
                    <TextBlock Text="Effects:" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Button Click="ReverseButton_Click" ToolTip="Reverse Selected Notes" Margin="1" Background="#4F4F4F" Foreground="White" BorderThickness="0" Padding="6,4" FontSize="11">⇅ Reverse</Button>
                    <Button Click="TransposeUpButton_Click" ToolTip="Transpose +1 Semitone" Margin="1" Background="#4F4F4F" Foreground="White" BorderThickness="0" Padding="6,4" FontSize="11">▲ +1</Button>
                    <Button Click="TransposeDownButton_Click" ToolTip="Transpose -1 Semitone" Margin="1" Background="#4F4F4F" Foreground="White" BorderThickness="0" Padding="6,4" FontSize="11">▼ -1</Button>
                    <Button Click="OctaveUpButton_Click" ToolTip="Octave Up (+12)" Margin="1" Background="#4F4F4F" Foreground="White" BorderThickness="0" Padding="6,4" FontSize="11">▲▲ +12</Button>
                    <Button Click="OctaveDownButton_Click" ToolTip="Octave Down (-12)" Margin="1" Background="#4F4F4F" Foreground="White" BorderThickness="0" Padding="6,4" FontSize="11">▼▼ -12</Button>
                    <Button Click="DoubleSpeedButton_Click" ToolTip="Double Speed" Margin="1" Background="#4F4F4F" Foreground="White" BorderThickness="0" Padding="6,4" FontSize="11">⏩ 2x</Button>
                    <Button Click="HalfSpeedButton_Click" ToolTip="Half Speed" Margin="1" Background="#4F4F4F" Foreground="White" BorderThickness="0" Padding="6,4" FontSize="11">⏪ 0.5x</Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN PIANO ROLL WORKSPACE -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>  <!-- Piano Keyboard -->
                <ColumnDefinition Width="*"/>   <!-- Scrolling Note Canvas -->
            </Grid.ColumnDefinitions>

            <!-- Piano Keyboard -->
            <ScrollViewer Grid.Column="0" x:Name="PianoScrollViewer" VerticalScrollBarVisibility="Hidden" ScrollChanged="PianoScrollViewer_ScrollChanged">
                <StackPanel x:Name="PianoKeyboardContainer" Background="#252526" Width="80">
                    <!-- Keys will be populated programmatically in code-behind -->
                </StackPanel>
            </ScrollViewer>

            <!-- Grid Canvas -->
            <ScrollViewer Grid.Column="1" x:Name="GridScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" ScrollChanged="GridScrollViewer_ScrollChanged">
                <Grid>
                    <!-- Visual Grid Canvas -->
                    <Canvas x:Name="PianoRollCanvas" Width="2000" Height="900" Background="#1E1E1E" 
                            MouseDown="PianoRollCanvas_MouseDown" 
                            MouseMove="PianoRollCanvas_MouseMove" 
                            MouseUp="PianoRollCanvas_MouseUp">
                        <!-- Beat vertical gridlines and Pitch horizontal gridlines will be rendered dynamically -->
                        <Rectangle x:Name="SelectionBox" Stroke="#FF8C00" StrokeThickness="1" StrokeDashArray="4 4" Fill="#33FF8C00" Visibility="Collapsed" Panel.ZIndex="1000"/>
                    </Canvas>
                    <!-- Active timeline cursor -->
                    <Canvas x:Name="TimelineCanvas" Width="2000" Height="900" IsHitTestVisible="False">
                        <Line x:Name="TimelineCursor" X1="0" Y1="0" X2="0" Y2="900" Stroke="#E81123" StrokeThickness="2" Visibility="Hidden"/>
                    </Canvas>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,1,0,0" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusBarText" Text="Ready" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Click="ShowLastSavedDetails_Click" x:Name="SavedDetailsButton" Visibility="Collapsed" Background="#3F3F46" Foreground="White" BorderThickness="0" Padding="8,2" FontSize="10">View Saved Details</Button>
            </Grid>
        </Border>
    </Grid>
</Window>
